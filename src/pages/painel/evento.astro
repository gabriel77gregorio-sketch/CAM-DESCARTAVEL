---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Detalhes do Evento" activeLink="dashboard">
  <div id="manager-loading" style="display: flex; justify-content: center; padding: 5rem;">
    <div style="width: 40px; height: 40px; border: 4px solid var(--bg-tertiary); border-top-color: var(--accent); border-radius: 50%; animation: spin 1s linear infinite"></div>
  </div>

  <div id="manager-container-root" style="display: none;"></div>

  <script>
    import React from 'react';
    import ReactDOM from 'react-dom/client';
    import EventDetailsManager from '../../components/dashboard/EventDetailsManager';

    const url = new URL(window.location.href);
    const slug = url.searchParams.get('slug');

    const loadingEl = document.getElementById('manager-loading');
    const containerEl = document.getElementById('manager-container-root');

    if (!slug) {
      window.location.href = '/painel';
    } else {
      if (loadingEl) loadingEl.style.display = 'none';
      if (containerEl) {
        containerEl.style.display = 'block';
        const root = ReactDOM.createRoot(containerEl);
        root.render(React.createElement(EventDetailsManager, { slug }));
      }
    }
  </script>
</DashboardLayout>

<style>
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>
