---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Cam Descartável — Um QR Code, todas as fotos do seu evento">
  <!-- Header -->
  <header class="header">
    <div class="header-container">
      <a href="/" class="logo">Cam <span>Descartável</span></a>
      <nav class="nav-links">
        <a href="#como-funciona">Como Funciona</a>
        <a href="#precos">Preços</a>
        <a href="#faq">FAQ</a>
        <a href="#presentes-lista">Para presente</a>
      </nav>
      <div class="auth-buttons">
        <a href="/painel" class="btn-ghost">Entrar</a>
        <a href="/painel" class="btn-red">Criar Evento</a>
      </div>
      <button class="menu-toggle" id="menuToggle" aria-label="Abrir Menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
    <!-- Mobile menu -->
    <div class="mobile-menu" id="mobileMenu">
      <a href="#como-funciona">Como Funciona</a>
      <a href="#precos">Preços</a>
      <a href="#faq">FAQ</a>
      <a href="#presentes-lista">Para presente</a>
      <hr />
      <a href="/painel" style="padding: 0.5rem 0;">Entrar</a>
      <a href="/painel" class="btn-red" style="text-align:center; margin-top: 0.5rem;">Criar Evento</a>
    </div>
  </header>

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content animate-fade-in">
      <h1>Um código QR: todas as fotos do casamento, de <span class="highlight">todos os convidados</span>.</h1>
      <p class="hero-subtitle">Configure um único código QR e todas as fotos do dia serão salvas em sua galeria privada — com qualidade original, diretamente dos celulares dos seus convidados, sem precisar instalar nada.</p>
      
      <a href="/painel" class="btn-primary btn-large">Comece sua galeria</a>
      
      <div class="trust-signals">
        <div class="trust-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E8318A" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span>Configuração em 3 etapas</span>
        </div>
        <div class="trust-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E8318A" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span>Não há aplicativo para hóspedes.</span>
        </div>
      </div>
    </div>

    <!-- Hero Visual Mockup -->
    <div class="hero-visual animate-fade-in">
      <div class="visual-wrapper">
        <!-- Mockup do celular com fotos de casamento reais -->
        <div class="phone-mockup">
          <div class="phone-notch"></div>
          <div class="phone-screen">
            <div class="phone-header">
              <span>Ivy & Noah</span>
              <small>22 de Agosto de 2025</small>
            </div>
            <div class="phone-stats">
              <div><strong>573</strong><span>Fotos</span></div>
              <div><strong>88</strong><span>Convidados</span></div>
            </div>
            <div class="phone-gallery-grid">
              <div class="grid-img" style="background-image: url('https://images.unsplash.com/photo-1519741497674-611481863552?w=800&auto=format&fit=crop&q=80')"></div>
              <div class="grid-img" style="background-image: url('https://images.unsplash.com/photo-1511285560929-80b456fea0bc?w=800&auto=format&fit=crop&q=80')"></div>
              <div class="grid-img" style="background-image: url('https://images.unsplash.com/photo-1583939003579-730e3918a45a?w=800&auto=format&fit=crop&q=80')"></div>
              <div class="grid-img" style="background-image: url('https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=800&auto=format&fit=crop&q=80')"></div>
              <div class="grid-img" style="background-image: url('https://images.unsplash.com/photo-1519225495810-7512c696505a?w=800&auto=format&fit=crop&q=80')"></div>
              <div class="grid-img" style="background-image: url('https://images.unsplash.com/photo-1507504038482-762102124e18?w=800&auto=format&fit=crop&q=80')"></div>
            </div>
          </div>
        </div>
        
        <!-- Plaqueta de Mesa QR flutuante -->
        <div class="floating-qr-card">
          <div class="qr-header">
            <h4>Ivy & Noah</h4>
            <p>22 de Agosto de 2025</p>
          </div>
          <div class="qr-code-placeholder">
            <!-- Representação gráfica de QR Code -->
            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#1a1a2e" stroke-width="1.5"><rect x="2" y="2" width="6" height="6" rx="1"/><rect x="2" y="16" width="6" height="6" rx="1"/><rect x="16" y="2" width="6" height="6" rx="1"/><rect x="10" y="10" width="4" height="4" rx="0.5"/><path d="M10 2h4M2 10v4M14 10h4M10 14v4M16 16h6v6h-6zM22 10v4M10 22h4"/></svg>
          </div>
          <p class="qr-scan-text">Escaneie para adicionar suas fotos</p>
          <span class="qr-domain">pixwedding.com</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Polaroid Overlapping Strip -->
  <section class="polaroid-strip">
    <div class="polaroid-wrapper">
      <div class="polaroid-card" style="transform: rotate(-6deg) translateY(10px);">
        <div class="polaroid-photo" style="background-image: url('https://images.unsplash.com/photo-1519741497674-611481863552?w=400&auto=format&fit=crop&q=80')"></div>
        <p class="polaroid-caption">Ivy & Noah</p>
      </div>
      <div class="polaroid-card" style="transform: rotate(4deg) translateY(-5px);">
        <div class="polaroid-photo" style="background-image: url('https://images.unsplash.com/photo-1511285560929-80b456fea0bc?w=400&auto=format&fit=crop&q=80')"></div>
        <p class="polaroid-caption">Primeira Dança</p>
      </div>
      <div class="polaroid-card" style="transform: rotate(-3deg) translateY(5px);">
        <div class="polaroid-photo" style="background-image: url('https://images.unsplash.com/photo-1583939003579-730e3918a45a?w=400&auto=format&fit=crop&q=80')"></div>
        <p class="polaroid-caption">Pista de Dança</p>
      </div>
      <div class="polaroid-card" style="transform: rotate(5deg) translateY(15px);">
        <div class="polaroid-photo" style="background-image: url('https://images.unsplash.com/photo-1523438885200-e635ba2c371e?w=400&auto=format&fit=crop&q=80')"></div>
        <p class="polaroid-caption">Momentos Espontâneos</p>
      </div>
      <div class="polaroid-card" style="transform: rotate(-4deg) translateY(-8px);">
        <div class="polaroid-photo" style="background-image: url('https://images.unsplash.com/photo-1507504038482-762102124e18?w=400&auto=format&fit=crop&q=80')"></div>
        <p class="polaroid-caption">Brinde aos Noivos</p>
      </div>
      <div class="polaroid-card" style="transform: rotate(2deg) translateY(2px);">
        <div class="polaroid-photo" style="background-image: url('https://images.unsplash.com/photo-1519225495810-7512c696505a?w=400&auto=format&fit=crop&q=80')"></div>
        <p class="polaroid-caption">Os Detalhes</p>
      </div>
    </div>
  </section>

  <!-- Como Funciona Section -->
  <section id="como-funciona" class="section section-alt">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-badge">Como funciona</span>
        <h2>Configure tudo <span class="highlight">hoje à noite</span>. No dia seguinte, todas as fotos estarão na galeria.</h2>
        <p>Nada para instalar — nem para você, nem para os seus convidados. Veja as 3 etapas simples:</p>
      </div>

      <div class="steps-container">
        <!-- Passo 1 -->
        <div class="step-row">
          <div class="step-info">
            <span class="step-number">01</span>
            <h3>Nomeie sua galeria</h3>
            <p>Digite os nomes do casal e a data do evento. Nós criamos sua galeria privada e um código QR exclusivo na hora — sem necessidade de configurar plug-ins ou integrações complexas.</p>
          </div>
          <div class="step-preview">
            <div class="preview-card-form">
              <div class="form-header">
                <span>Nova galeria de casamento</span>
              </div>
              <div class="form-body-preview">
                <div class="input-preview-group">
                  <label>O CASAL</label>
                  <div class="input-preview-box">Ivy & Noah</div>
                </div>
                <div class="input-preview-group">
                  <label>DATA DO CASAMENTO</label>
                  <div class="input-preview-box">22 de Agosto de 2025</div>
                </div>
                <button type="button" class="btn-primary-preview">Criar Galeria</button>
              </div>
            </div>
          </div>
        </div>

        <!-- Passo 2 -->
        <div class="step-row reverse">
          <div class="step-info">
            <span class="step-number">02</span>
            <h3>Imprima o QR Code</h3>
            <p>Baixe placas prontas para impressão ou cartões de mesa personalizados. Ao escanear o código, seus convidados podem usar a câmera vintage do app ou <strong>fazer o upload de fotos normais da galeria do próprio celular</strong>.</p>
          </div>
          <div class="step-preview">
            <div class="preview-card-print">
              <div class="card-print-frame">
                <div class="card-print-logo">IVY & NOAH</div>
                <div class="card-print-sub">Escaneie para adicionar suas fotos</div>
                <div class="card-print-qr">
                  <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="#E8318A" stroke-width="1.5"><rect x="2" y="2" width="6" height="6" rx="1"/><rect x="2" y="16" width="6" height="6" rx="1"/><rect x="16" y="2" width="6" height="6" rx="1"/><rect x="10" y="10" width="4" height="4" rx="0.5"/><path d="M10 2h4M2 10v4M14 10h4M10 14v4M16 16h6v6h-6zM22 10v4M10 22h4"/></svg>
                </div>
                <div class="card-print-footer">pixwedding.com</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Passo 3 -->
        <div class="step-row">
          <div class="step-info">
            <span class="step-number">03</span>
            <h3>Baixe a galeria inteira</h3>
            <p>Os convidados apontam a câmera, tiram fotos ou fazem o upload direto e voltam para curtir a festa. No dia seguinte, você pode baixar todas as fotos em qualidade original de uma única vez.</p>
          </div>
          <div class="step-preview">
            <div class="preview-card-download">
              <div class="download-title">Fotos prontas para baixar</div>
              <div class="download-count">573</div>
              <div class="download-label">Fotos coletadas com qualidade original</div>
              <button class="btn-primary-preview">Baixar Galeria (ZIP)</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Um Único Código, de qualquer celular (Visual Showroom) -->
  <section id="celular" class="section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-badge">Experiência Completa</span>
        <h2>Um único código, <span class="highlight">em qualquer celular</span>.</h2>
        <p>A experiência do convidado é otimizada para navegadores móveis, sem download de aplicativos. E o painel administrativo oferece controle total em tempo real.</p>
      </div>

      <div class="showroom-grid">
        <!-- View 1: Camera do Convidado -->
        <div class="showroom-item">
          <div class="showroom-phone">
            <div class="phone-screen camera-bg">
              <div class="camera-lens-view">
                <div class="viewfinder-grid"></div>
              </div>
              <div class="camera-lcd">10 FOTOS RESTANTES</div>
              <div class="camera-controls">
                <div class="flash-btn">⚡</div>
                <div class="shutter-btn"></div>
                <div class="filter-btn">🎨</div>
              </div>
            </div>
          </div>
          <h4>Câmera do Convidado</h4>
          <p>Visual retrô de câmera descartável com flash e filtros vintage automáticos diretamente no navegador.</p>
        </div>

        <!-- View 2: Galeria Pública -->
        <div class="showroom-item">
          <div class="showroom-phone">
            <div class="phone-screen gallery-bg">
              <div class="gallery-header">Galeria ao Vivo</div>
              <div class="gallery-pics">
                <div class="pic-box" style="background-image: url('https://images.unsplash.com/photo-1519741497674-611481863552?w=800&auto=format&fit=crop&q=80')"></div>
                <div class="pic-box" style="background-image: url('https://images.unsplash.com/photo-1511285560929-80b456fea0bc?w=800&auto=format&fit=crop&q=80')"></div>
                <div class="pic-box" style="background-image: url('https://images.unsplash.com/photo-1583939003579-730e3918a45a?w=800&auto=format&fit=crop&q=80')"></div>
                <div class="pic-box" style="background-image: url('https://images.unsplash.com/photo-1523438885200-e635ba2c371e?w=800&auto=format&fit=crop&q=80')"></div>
              </div>
            </div>
          </div>
          <h4>Galeria Digital Coletiva</h4>
          <p>Um feed atualizado em tempo real para os convidados acompanharem e relembrarem os cliques do evento.</p>
        </div>

        <!-- View 3: Painel Administrativo -->
        <div class="showroom-item">
          <div class="showroom-phone">
            <div class="phone-screen admin-bg">
              <div class="admin-header">Painel do Casal</div>
              <div class="admin-stats-box">
                <div><strong>573</strong><span>Fotos</span></div>
                <div><strong>88</strong><span>Pessoas</span></div>
              </div>
              <div class="admin-actions-preview">
                <div class="action-row-preview">Baixar Tudo (ZIP)</div>
                <div class="action-row-preview">Gerar Kit de Mesa A4</div>
                <div class="action-row-preview">Encomendar Revelações</div>
              </div>
            </div>
          </div>
          <h4>Painel do Casal</h4>
          <p>Acesse estatísticas, faça downloads em alta definição e gerencie as fotos e limites do evento.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section id="depoimentos" class="section section-alt">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-badge">Feedback dos Casais</span>
        <h2>O que os noivos <span class="highlight">nos contam depois</span>.</h2>
        <p>Relatos sinceros de casais que substituíram as câmeras descartáveis tradicionais em suas festas.</p>
      </div>

      <div class="testimonials-masonry">
        <div class="testimonial-card">
          <p>“Tivemos um casamento enorme e eu já estava temendo a parte de passar semanas pedindo fotos para todo mundo. Sinceramente, não precisei. As pessoas escanearam a plaquinha nas mesas e pronto, tudo apareceu em um só lugar. Coletamos mais de 800 fotos. Muito feliz por ter feito isso.”</p>
          <div class="testimonial-meta">
            <strong>Niamh & Conor</strong>
            <span>803 fotos · 124 convidados</span>
          </div>
        </div>

        <div class="testimonial-card">
          <p>“Minha foto favorita de todo o casamento não veio do fotógrafo profissional, veio da galeria dos convidados. É uma foto do meu pai rindo no meio do discurso dele. Eu nem sabia que ela existia até abrir o painel na semana seguinte.”</p>
          <div class="testimonial-meta">
            <strong>Mei & Riku</strong>
            <span>624 fotos · 96 guests</span>
          </div>
        </div>

        <div class="testimonial-card">
          <p>“Não tínhamos certeza se os convidados realmente usariam, mas usaram muito! Até os amigos mais velhos dos meus pais conseguiram usar sem problemas. As fotos espontâneas e levemente desfocadas do final da noite são as melhores!”</p>
          <div class="testimonial-meta">
            <strong>Brooke & Cole</strong>
            <span>461 fotos · 69 convidados</span>
          </div>
        </div>

        <div class="testimonial-card">
          <p>“Colocamos as plaquinhas de QR Code nas mesas, esquecemos disso durante a festa e acordamos no dia seguinte com centenas de fotos na galeria privada. Foi a coisa mais simples e sem complicação que contratamos para todo o casamento.”</p>
          <div class="testimonial-meta">
            <strong>Thandi & Sam</strong>
            <span>372 fotos · 58 convidados</span>
          </div>
        </div>

        <div class="testimonial-card">
          <p>“Nossa fotógrafa foi fantástica, mas ela não podia estar em todos os lugares ao mesmo tempo. A galeria coletiva capturou os momentos que ela não alcançou: as crianças brincando sob as mesas, minha tia emocionada, os amigos dançando descalços. Detalhes incríveis.”</p>
          <div class="testimonial-meta">
            <strong>Lucía & Mateo</strong>
            <span>556 fotos · 83 convidados</span>
          </div>
        </div>

        <div class="testimonial-card">
          <p>“Estávamos em dúvida se valia a pena pagar, mas superou as expectativas. Apenas uma plaquinha em cada mesa e os convidados fizeram o resto. Não precisamos ficar perseguindo ninguém no WhatsApp para nos enviar as fotos.”</p>
          <div class="testimonial-meta">
            <strong>Freja & Anders</strong>
            <span>410 fotos · 64 convidados</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Um Único Código Para Toda a Celebração -->
  <section class="section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-badge">Casos de Uso</span>
        <h2>Um único código para <span class="highlight">toda a celebração</span>.</h2>
        <p>O mesmo QR Code funciona desde o jantar de ensaio até o brunch de despedida — coletando todos os momentos do fim de semana em um único álbum.</p>
      </div>

      <div class="use-cases-grid">
        <div class="use-case-card" style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1519741497674-611481863552?w=500&auto=format&fit=crop&q=80')">
          <div class="use-case-content">
            <h4>Os Votos</h4>
            <p>Cada lágrima de felicidade e a troca de alianças, capturada do ponto de vista único dos convidados que os fotógrafos contratados não conseguem registrar.</p>
          </div>
        </div>

        <div class="use-case-card" style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1583939003579-730e3918a45a?w=500&auto=format&fit=crop&q=80')">
          <div class="use-case-content">
            <h4>A Festa</h4>
            <p>Os discursos emocionantes na mesa principal, a primeira dança do casal e os convidados se divertindo na pista de dança até tarde da noite.</p>
          </div>
        </div>

        <div class="use-case-card" style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1523438885200-e635ba2c371e?w=500&auto=format&fit=crop&q=80')">
          <div class="use-case-content">
            <h4>Tarde da Noite</h4>
            <p>Depois que os profissionais de foto e vídeo já foram para casa — os registros descontraídos, espontâneos e divertidos da pista de dança.</p>
          </div>
        </div>

        <div class="use-case-card" style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1507504038482-762102124e18?w=500&auto=format&fit=crop&q=80')">
          <div class="use-case-content">
            <h4>O Dia Anterior</h4>
            <p>O jantar de ensaio com a família, os momentos espontâneos de preparação e os drinques de boas-vindas — tudo alimentando o mesmo álbum.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Placas de mesa prontas para impressão -->
  <section class="section section-alt">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-badge">Kit de Mesa</span>
        <h2>Placas de mesa prontas, <span class="highlight">feitas para você</span>.</h2>
        <p>Nós geramos automaticamente placas e cartões de mesa elegantes em PDF A4. Basta adicionar seus nomes, baixar o documento e imprimir!</p>
      </div>

      <div class="print-templates-row">
        <div class="template-item">
          <div class="template-box">
            <div class="template-box-content">
              <h5>Seja Bem-vindo</h5>
              <p>Escaneie e envie suas fotos</p>
              <div class="template-qr-mini">QR</div>
            </div>
          </div>
          <span>Placa de Recepção</span>
        </div>

        <div class="template-item">
          <div class="template-box dark">
            <div class="template-box-content">
              <h5>Compartilhe os Momentos</h5>
              <p>Escaneie para abrir a câmera</p>
              <div class="template-qr-mini">QR</div>
            </div>
          </div>
          <span>Cartão de Mesa Minimalista</span>
        </div>

        <div class="template-item">
          <div class="template-box">
            <div class="template-box-content">
              <h5>Ajude-nos a Lembrar</h5>
              <p>Tire fotos vintage da festa</p>
              <div class="template-qr-mini">QR</div>
            </div>
          </div>
          <span>Cartão de Mesa Vintage</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Preços Section -->
  <section id="precos" class="section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-badge">Valores</span>
        <h2>Planos sem pegadinha: <span class="highlight">menos que um buquê de flores</span>.</h2>
        <p>Pague uma única vez pelo seu evento. Sem assinaturas recorrentes, cobranças adicionais ou pegadinhas.</p>
      </div>

      <div class="pricing-container">
        <!-- Plano Starter -->
        <div class="pricing-card">
          <h3>Starter</h3>
          <div class="price">R$ 49<span>/evento</span></div>
          <p class="price-desc">Ideal para pequenas festas ou eventos de um único dia.</p>
          <ul class="price-features">
            <li>Fotos e vídeos ilimitados</li>
            <li>Quantidade ilimitada de convidados</li>
            <li>Prazo de 3 meses para envios</li>
            <li>Armazenamento de 6 meses</li>
            <li>Todos os recursos inclusos</li>
          </ul>
