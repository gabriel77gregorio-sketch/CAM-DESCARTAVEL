    align-items: center;
    gap: 0.6rem;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .price-features li::before {
    content: "✓";
    color: var(--accent);
    font-weight: bold;
    flex-shrink: 0;
  }

