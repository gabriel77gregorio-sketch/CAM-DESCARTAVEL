  }

  .wedding-registry .emoji-float {
    left: 2rem;
    right: auto;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-15px); }
  }

  /* ===== RESPONSIVE ===== */
