---
import BaseLayout from '../layouts/BaseLayout.astro';
import RegisterForm from '../components/auth/RegisterForm';
---

<BaseLayout title="Criar Conta — Cam Descartável">
  <div style="min-height: 100vh; display: flex; align-items: center; justify-content: center; background-color: #fef2f6; padding: 2rem 1rem;">
    <div style="width: 100%; display: flex; flex-direction: column; align-items: center; gap: 2.5rem;">
      <a href="/" style="font-family: var(--font-display); font-size: 2.5rem; font-weight: 700; color: var(--text-primary); text-decoration: none;">
        Cam <span style="color: #E8318A;">Descartável</span>
      </a>
      <RegisterForm client:load />
    </div>
  </div>

  <script>
    import { supabase } from '../lib/supabase';
    supabase.auth.getSession().then(({ data: { session } }) => {
      if (session) {
        window.location.href = '/painel';
      }
    });
  </script>
</BaseLayout>
