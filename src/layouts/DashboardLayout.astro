---
import '../styles/global.css';
import '../styles/dashboard.css';

interface Props {
  title: string;
  activeLink?: 'dashboard' | 'novo-evento' | 'album' | 'imprimir' | 'configuracoes';
}

const { title, activeLink = 'dashboard' } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#ffffff" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Painel Cam Descartável</title>
  </head>
  <body>
    <div class="grain-overlay"></div>
    <div class="dashboard-container">
      <!-- Mobile Topbar -->
      <div class="mobile-topbar">
        <a href="/painel" class="dash-brand">
          Cam <span>Descartável</span>
        </a>
        <div class="dash-topbar-right">
          <div id="user-avatar-mobile" class="user-avatar user-avatar--sm">C</div>
        </div>
      </div>

      <!-- Sidebar / Bottom Nav -->
      <aside class="sidebar">
        <!-- Desktop: Brand -->
        <div class="sidebar-brand">
          Cam <span>Descartável</span>
        </div>

        <!-- Nav Links -->
        <nav class="sidebar-menu">
          <a href="/painel" class={`sidebar-link ${activeLink === 'dashboard' ? 'active' : ''}`}>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
            <span>Lar</span>
          </a>

          <a href="/painel/album" class={`sidebar-link ${activeLink === 'album' ? 'active' : ''}`}>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
              <circle cx="9" cy="9" r="2"/>
              <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
            </svg>
            <span>Álbum</span>
          </a>

          <a href="/painel/imprimir" class={`sidebar-link ${activeLink === 'imprimir' ? 'active' : ''}`}>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/>
              <path d="M6 9V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v5"/>
              <rect x="6" y="14" width="12" height="8" rx="1"/>
            </svg>
            <span>Imprimir</span>
          </a>

          <a href="/painel/configuracoes" class={`sidebar-link ${activeLink === 'configuracoes' ? 'active' : ''}`}>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="3"/>
              <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
            </svg>
            <span>Ajustes</span>
          </a>
        </nav>

        <!-- Desktop: User Profile -->
        <div class="user-profile-nav">
          <div class="user-profile-inner">
            <div id="user-avatar-desktop" class="user-avatar">C</div>
            <div class="user-info">
              <span id="user-name-display" class="user-name">Usuário</span>
              <button id="logout-btn" class="logout-btn">Sair</button>
            </div>
          </div>
        </div>
      </aside>
      
      <!-- Conteúdo Principal -->
      <main class="main-content">
        <slot />
      </main>
    </div>

    <script>
      import { supabase } from '../lib/supabase';

      // Proteção de Rota e Dados do Usuário
      supabase.auth.getSession().then(({ data: { session } }) => {
        if (!session) {
          window.location.href = '/login';
        } else {
          const user = session.user;
          const meta = user.user_metadata || {};
          const name = meta.full_name || meta.name || user.email?.split('@')[0] || 'Usuário';
          const avatarUrl = meta.avatar_url || meta.picture;
          const initial = name.charAt(0).toUpperCase();

          const avatarMobile = document.getElementById('user-avatar-mobile');
          const avatarDesktop = document.getElementById('user-avatar-desktop');
          const nameDisplay = document.getElementById('user-name-display');

          if (nameDisplay) nameDisplay.textContent = name;

          [avatarMobile, avatarDesktop].forEach(el => {
            if (!el) return;
            if (avatarUrl) {
              (el as HTMLElement).style.backgroundImage = `url('${avatarUrl}')`;
              el.textContent = '';
            } else {
              el.textContent = initial;
            }
          });
        }
      });
      
      const logoutBtn = document.getElementById('logout-btn');
      if (logoutBtn) {
        logoutBtn.addEventListener('click', async () => {
          await supabase.auth.signOut();
          window.location.href = '/login';
        });
      }
    </script>
  </body>
</html>

<style>
  /* ─── Brand ──────────────────────────────────────────────── */
  .dash-brand {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-primary);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.2rem;
  }
  .dash-brand span { color: var(--accent-wedding); }

  .dash-topbar-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* ─── Avatares ────────────────────────────────────────────── */
  .user-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: var(--accent);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-family: var(--font-display);
    font-size: 1rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    background-size: cover;
    background-position: center;
    flex-shrink: 0;
  }

  .user-avatar--sm {
    width: 32px;
    height: 32px;
    font-size: 0.875rem;
  }

  /* ─── User Profile (Desktop Sidebar) ─────────────────────── */
  .user-profile-inner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0.5rem;
    width: 100%;
  }

  .user-info {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    overflow: hidden;
  }

  .user-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
    max-width: 140px;
    display: block;
  }

  .logout-btn {
    border: none;
    background: none;
    color: var(--text-tertiary);
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
    padding: 0;
    font-family: var(--font-sans);
    transition: color var(--transition-fast);
  }

  .logout-btn:hover {
    color: #ef4444;
  }
</style>
