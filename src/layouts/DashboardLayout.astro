---
import '../styles/global.css';
import '../styles/dashboard.css';

interface Props {
  title: string;
  activeLink?: 'dashboard' | 'novo-evento' | 'album' | 'imprimir';
}

const { title, activeLink = 'dashboard' } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Painel Cam Descartável</title>
    

  </head>
  <body>
    <div class="grain-overlay"></div>
    <div class="dashboard-container">
      <!-- Mobile Topbar -->
      <div class="mobile-topbar">
        <div class="sidebar-brand" style="font-family: var(--font-display); font-size: 1.4rem; font-weight: 700; color: #1a1a2e; display: flex; align-items: center; gap: 0.25rem; margin-bottom: 0;">
          Cam <span style="color: #E8318A;">Descartável</span>
        </div>
        <!-- User initial circle avatar (Mobile) -->
        <div style="display: flex; align-items: center; gap: 0.5rem;">
          <div id="user-avatar-mobile" style="width: 28px; height: 28px; border-radius: 50%; background-color: #E8318A; color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-family: var(--font-display); font-size: 0.85rem; box-shadow: 0 2px 8px rgba(232, 49, 138, 0.3); background-size: cover; background-position: center;">
            C
          </div>
        </div>
      </div>

      <!-- Sidebar / Bottom Nav -->
      <aside class="sidebar">
        <div style="width: 100%;">
          <div class="sidebar-brand" style="font-family: var(--font-display); font-size: 1.6rem; font-weight: 700; color: #1a1a2e; margin-bottom: 2.5rem; display: flex; align-items: center; gap: 0.25rem;">
            Cam <span style="color: #E8318A;">Descartável</span>
          </div>
          <nav class="sidebar-menu">
            <a href="/painel" class={`sidebar-link ${activeLink === 'dashboard' ? 'active' : ''}`} style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; border-radius: 8px; font-weight: 500; text-decoration: none; color: #555; transition: all 0.2s;">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              <span>Lar</span>
            </a>
            <a href="/painel/album" class={`sidebar-link ${activeLink === 'album' ? 'active' : ''}`} style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; border-radius: 8px; font-weight: 500; text-decoration: none; color: #555; transition: all 0.2s;">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
              <span>Álbum</span>
            </a>
            <a href="/painel/imprimir" class={`sidebar-link ${activeLink === 'imprimir' ? 'active' : ''}`} style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; border-radius: 8px; font-weight: 500; text-decoration: none; color: #555; transition: all 0.2s;">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><path d="M6 9V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v5"/><rect x="6" y="14" width="12" height="8" rx="1"/></svg>
              <span>Imprimir fotos</span>
            </a>
            <a href="/painel/configuracoes" class={`sidebar-link ${activeLink === 'configuracoes' ? 'active' : ''}`} style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; border-radius: 8px; font-weight: 500; text-decoration: none; color: #555; transition: all 0.2s;">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
              <span>Ajustes</span>
            </a>
          </nav>
        </div>
        
        <div class="user-profile-nav" style="display: flex; flex-direction: column; gap: 1rem; align-items: flex-start; width: 100%;">
          <!-- User initial circle avatar -->
          <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.5rem 1rem;">
            <div id="user-avatar-desktop" style="width: 32px; height: 32px; border-radius: 50%; background-color: #E8318A; color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-family: var(--font-display); font-size: 0.95rem; box-shadow: 0 2px 8px rgba(232, 49, 138, 0.3); background-size: cover; background-position: center; flex-shrink: 0;">
              C
            </div>
            <div style="display: flex; flex-direction: column; align-items: flex-start; overflow: hidden;">
              <span id="user-name-display" style="font-size: 0.85rem; font-weight: 600; color: #1a1a2e; margin-bottom: -2px; white-space: nowrap; text-overflow: ellipsis; overflow: hidden; max-width: 130px;">
                Usuário
              </span>
              <button id="logout-btn" style="border: none; background: none; color: #999; font-size: 0.75rem; font-weight: 500; cursor: pointer; padding: 0;">
                Sair
              </button>
            </div>
          </div>
        </div>
      </aside>
      
      <!-- Conteúdo Principal -->
      <main class="main-content">
        <slot />
      </main>
    </div>

    <script>
      import { supabase } from '../lib/supabase';

      // Proteção de Rota e Dados do Usuário
      supabase.auth.getSession().then(({ data: { session } }) => {
        if (!session) {
          window.location.href = '/login';
        } else {
          // Extrair informações do provedor (Google)
          const user = session.user;
          const meta = user.user_metadata || {};
          const name = meta.full_name || meta.name || user.email?.split('@')[0] || 'Usuário';
          const avatarUrl = meta.avatar_url || meta.picture;
          const initial = name.charAt(0).toUpperCase();

          // Atualizar DOM
          const avatarMobile = document.getElementById('user-avatar-mobile');
          const avatarDesktop = document.getElementById('user-avatar-desktop');
          const nameDisplay = document.getElementById('user-name-display');

          if (nameDisplay) nameDisplay.textContent = name;

          [avatarMobile, avatarDesktop].forEach(el => {
            if (!el) return;
            if (avatarUrl) {
              el.style.backgroundImage = `url('${avatarUrl}')`;
              el.textContent = ''; // Limpa a letra "C"
            } else {
              el.textContent = initial;
            }
          });
        }
      });
      
      const logoutBtn = document.getElementById('logout-btn');
      if (logoutBtn) {
        logoutBtn.addEventListener('click', async () => {
          await supabase.auth.signOut();
          window.location.href = '/login';
        });
      }
    </script>
  </body>
</html>
